    "Runs entirely on-device — no network after download. Falls back to Apple speech recognition when disabled, unavailable, or the model is not yet downloaded.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs entirely on-device — no network after download. Falls back to Apple speech recognition when disabled, unavailable, or the model is not yet downloaded."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Läuft vollständig auf dem Gerät – keine Netzwerkverbindung nach dem Download. Greift auf die Apple-Spracherkennung zurück, wenn deaktiviert, nicht verfügbar oder das Modell noch nicht heruntergeladen ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Se ejecuta completamente en el dispositivo: sin red después de la descarga. Recurre al reconocimiento de voz de Apple cuando está desactivado, no disponible o el modelo aún no se ha descargado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Fonctionne entièrement sur l'appareil — aucun réseau après le téléchargement. Revient à la reconnaissance vocale d'Apple lorsqu'il est désactivé, indisponible ou que le modèle n'est pas encore téléchargé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "すべてオンデバイスで動作し、ダウンロード後はネットワーク不要です。無効・利用不可・モデル未ダウンロードの場合は Apple の音声認識にフォールバックします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "모든 처리가 기기에서 실행되며 다운로드 후에는 네트워크가 필요하지 않습니다. 비활성화되었거나 사용할 수 없거나 모델이 아직 다운로드되지 않은 경우 Apple 음성 인식으로 대체됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "完全在设备端运行——下载后无需联网。在关闭、不可用或模型尚未下载时回退到 Apple 语音识别。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "完全在裝置端執行——下載後無需連網。在關閉、不可用或模型尚未下載時回退至 Apple 語音辨識。"
          }
        }
      }
    },
