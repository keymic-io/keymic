    "Shell actions run with your full user privileges. Only add shortcuts you trust.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Shell-Aktionen werden mit deinen vollen Benutzerrechten ausgeführt. Füge nur Kurzbefehle hinzu, denen du vertraust."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shell actions run with your full user privileges. Only add shortcuts you trust."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Las acciones de Shell se ejecutan con todos tus privilegios de usuario. Añade solo atajos en los que confíes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Les actions Shell s’exécutent avec vos privilèges utilisateur complets. N’ajoutez que des raccourcis de confiance."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Shell アクションはあなたのフル権限で実行されます。信頼できるショートカットのみ追加してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Shell 동작은 사용자 전체 권한으로 실행됩니다. 신뢰하는 단축키만 추가하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Shell 动作以你的完整用户权限运行。仅添加你信任的快捷键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Shell 動作以你的完整使用者權限執行。僅新增你信任的快速鍵。"
          }
        }
      }
    },
