    "Stores text clipboards only. Password-manager clipboards are ignored by default.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Speichert nur Text-Zwischenablagen. Zwischenablagen von Passwort-Managern werden standardmäßig ignoriert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stores text clipboards only. Password-manager clipboards are ignored by default."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Solo se almacenan portapapeles de texto. Los portapapeles de gestores de contraseñas se ignoran por defecto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Conserve uniquement les presse-papiers texte. Les presse-papiers des gestionnaires de mots de passe sont ignorés par défaut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "テキストのクリップボードのみを保存します。パスワードマネージャーのクリップボードはデフォルトで無視されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "텍스트 클립보드만 저장합니다. 비밀번호 관리자의 클립보드는 기본적으로 무시됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅存储文本剪贴板内容。密码管理器的剪贴板默认会被忽略。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "僅儲存文字剪貼簿內容。密碼管理工具的剪貼簿預設會被略過。"
