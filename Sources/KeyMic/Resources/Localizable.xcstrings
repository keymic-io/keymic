    "Single-key remap. Add a mapping, press the desired key. Esc / Return / Delete exit recording.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Einzeltasten-Neuzuordnung. Eine Zuordnung hinzufügen und die gewünschte Taste drücken. Esc / Return / Delete beendet die Aufzeichnung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single-key remap. Add a mapping, press the desired key. Esc / Return / Delete exit recording."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Reasignación de una sola tecla. Añade una asignación y pulsa la tecla deseada. Esc / Return / Delete sale de la grabación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Réassignation d’une seule touche. Ajoutez un mappage, puis appuyez sur la touche souhaitée. Esc / Return / Delete quitte l’enregistrement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "シングルキーの再マッピング。マッピングを追加し、目的のキーを押してください。Esc / Return / Delete で録音を終了します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "단일 키 재매핑. 매핑을 추가한 뒤 원하는 키를 누르세요. Esc / Return / Delete로 녹화를 종료합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "单键重映射。添加一条映射后按下目标键。按 Esc / Return / Delete 退出录制。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "單鍵重新對應。新增一筆對應後按下目標鍵。按 Esc / Return / Delete 退出錄製。"
          }
        }
      }
    },
    "Source and target must differ": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Quell- und Zieltaste müssen unterschiedlich sein"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Source and target must differ"
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "La tecla de origen y la de destino deben ser distintas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "La touche source et la touche cible doivent être différentes"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ソースキーとターゲットキーは異なる必要があります"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "원본 키와 대상 키는 달라야 합니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "来源键与目标键必须不同"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "來源鍵與目標鍵必須不同"
          }
        }
      }
    },
    "Speech recognition denied.\nGrant in System Settings → Privacy & Security → Speech Recognition.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Spracherkennung verweigert.\nIn „Systemeinstellungen → Datenschutz & Sicherheit → Spracherkennung“ erteilen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Speech recognition denied.\nGrant in System Settings → Privacy & Security → Speech Recognition."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Reconocimiento de voz denegado.\nConcédelo en « Ajustes del Sistema → Privacidad y seguridad → Reconocimiento de voz »."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Reconnaissance vocale refusée.\nAccordez-la dans « Réglages système → Confidentialité et sécurité → Reconnaissance vocale »."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "音声認識が拒否されました。\n「システム設定 → プライバシーとセキュリティ → 音声認識」で許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "음성 인식이 거부되었습니다.\n「시스템 설정 → 개인정보 보호 및 보안 → 음성 인식」에서 허용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音识别权限被拒绝。\n请在「系统设置 → 隐私与安全性 → 语音识别」中授权。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "語音識別權限被拒絕。\n請在「系統設定 → 隱私權與安全性 → 語音識別」中授權。"
          }
        }
      }
    },
    "Speech recognition is not supported for %@. Please check that the language is downloaded in System Settings → General → Keyboard → Dictation.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Spracherkennung wird für %@ nicht unterstützt. Bitte stelle in „Systemeinstellungen → Allgemein → Tastatur → Diktat“ sicher, dass die Sprache geladen ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Speech recognition is not supported for %@. Please check that the language is downloaded in System Settings → General → Keyboard → Dictation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "El reconocimiento de voz no es compatible con %@. Comprueba que el idioma esté descargado en « Ajustes del Sistema → General → Teclado → Dictado »."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "La reconnaissance vocale n’est pas prise en charge pour %@. Vérifiez que la langue est téléchargée dans « Réglages système → Général → Clavier → Dictée »."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ は音声認識に対応していません。「システム設定 → 一般 → キーボード → 音声入力」で言語をダウンロードしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@은(는) 음성 인식이 지원되지 않습니다. 「시스템 설정 → 일반 → 키보드 → 받아쓰기」에서 해당 언어를 다운로드하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 不支持语音识别。请在「系统设置 → 通用 → 键盘 → 听写」中下载该语言。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ 不支援語音識別。請在「系統設定 → 一般 → 鍵盤 → 聽寫」中下載該語言。"
          }
        }
      }
    },
